  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& (Join-Path $env:CLAUDE_PROJECT_DIR '.claude\\hooks\\docs_memory_reminder.ps1')"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& (Join-Path $env:CLAUDE_PROJECT_DIR '.claude\\hooks\\ensure_docs_memory_updated.ps1')"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& (Join-Path $env:CLAUDE_PROJECT_DIR '.claude\\hooks\\inject_memory_bank.ps1')"
          }
        ]
      }
    ]
  }
